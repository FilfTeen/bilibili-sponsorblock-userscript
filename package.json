{
  "name": "bilibili-sponsorblock-userscript",
  "version": "0.3.7",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-only",
  "description": "Tampermonkey userscript port of the core BilibiliSponsorBlock experience.",
  "repository": {
    "type": "git",
    "url": "https://github.com/FilfTeen/bilibili-sponsorblock-userscript.git"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "capture:bilibili": "BSB_SMOKE_CAPTURE_DIR=output/playwright node ./scripts/smoke-bilibili.mjs",
    "check": "tsc --noEmit",
    "evaluate:recognition": "node ./scripts/evaluate-recognition.mjs",
    "investigate:safari-player": "python3 ./scripts/safari-investigate-player-overlay.py",
    "smoke:bilibili": "node ./scripts/smoke-bilibili.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:safari": "python3 ./scripts/safari-validate.py",
    "verify:compat": "node ./scripts/verify-compat.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "esbuild": "^0.25.10",
    "jsdom": "^29.0.1",
    "playwright-core": "^1.56.1",
    "typescript": "^5.9.2",
    "vitest": "^4.1.1"
  }
}
